{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Console",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/SB-HR-Service.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] [{Level}] ({ThreadId}) <{SourceContext}> {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/SB-HR-Service.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff}] [{Level}] ({ThreadId}) <{SourceContext}> {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=SREE-PC\\MSSQL16;Database=SecurityDB;User ID=sa;Password=sa123;Encrypt=True;TrustServerCertificate=true",
          "tableName": "HRLog",
          "autoCreateSqlTable": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithExceptionDetails", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*",

  "AllowedOrigins": [
    "https://localhost:4200",
    "http://localhost:4200",
    "https://localhost:5200",
    "https://localhost:44358"
  ],

  "SharedJwtSettings": {
    "Key": "aKd83jFhLzqP9s3yBnW6XpG7VzRjL2XmH5tW4CvF7Ds9JcX2NrQ8TyH6MzKb9VhP",
    "Issuer": "https://localhost:44357",
    "Audience": "https://localhost:44357"
  },

  "RedisSettings": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "SBERP_HR_"
  },

  "ConnectionStrings": {
    "HRDatabase": "Server=SREE-PC\\MSSQL16;Database=HumanResourcesDB;User ID=sa;Password=sa123;Encrypt=True;TrustServerCertificate=true"
  }
}